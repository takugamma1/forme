{%- comment -%}
  ============================================================
  Hero Slider — sections/hero-slider.liquid
  STEP 1: semantic HTML5 + Liquid skeleton ONLY.
  No CSS, no JavaScript, and no schema tag yet (those come in later steps).

  Strict BEM. Block: `hero-slider`. Mobile-first source order:
  slides → promos → pagination → usp.

  Dynamic content binds to section blocks (defined in the schema step):
    • 'slide' → image + heading + description + CTA
    • 'promo' → image + label + url   (the "НОВО" / "НОВА КОЛЕКЦИЯ" cards)
    • 'usp'   → icon + text           (bottom feature bar)

  Heading is <h2> on purpose: on the index template the header already
  outputs a visually-hidden <h1> (shop name), and a slider has many slides,
  so an <h1> per slide would create duplicate/multiple H1s. Trivial to flip.
  ============================================================
{%- endcomment -%}

{%- liquid
  assign slides = section.blocks | where: 'type', 'slide'
  assign promos = section.blocks | where: 'type', 'promo'
  assign usps = section.blocks | where: 'type', 'usp'
-%}

<section
  class="hero-slider"
  aria-roledescription="carousel"
  aria-label="{{ section.settings.accessibility_label | default: 'Hero' | escape }}"
  {%- if section.settings.autoplay %} data-autoplay-interval="{{ section.settings.autoplay_interval | default: 5 | times: 1000 }}"{% endif %}
>
  <div class="hero-slider__main">
  {%- comment -%} ===== SLIDES: per-slide full-bleed media + left-aligned content ===== {%- endcomment -%}
  <div class="hero-slider__slides" aria-live="polite">
    {%- for block in slides -%}
      {%- liquid
        assign slide_loading = 'lazy'
        assign slide_priority = 'low'
        if forloop.first
          assign slide_loading = 'eager'
          assign slide_priority = 'high'
        endif
      -%}
      <div
        class="hero-slider__slide{% if forloop.first %} hero-slider__slide--active{% endif %}"
        role="group"
        aria-roledescription="slide"
        aria-label="{{ forloop.index }} / {{ slides.size }}"
        {{ block.shopify_attributes }}
      >
        <div class="hero-slider__media">
          {%- if block.settings.video != blank -%}
            {%- liquid
              assign poster_url = ''
              if block.settings.image != blank
                assign poster_url = block.settings.image | image_url: width: 1500
              elsif block.settings.video.preview_image != blank
                assign poster_url = block.settings.video.preview_image | image_url: width: 1500
              endif
            -%}
            <video
              class="hero-slider__video"
              autoplay
              loop
              muted
              playsinline
              preload="auto"
              {% if poster_url != blank %}poster="{{ poster_url }}"{% endif %}
            >
              {%- for source in block.settings.video.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>
          {%- elsif block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 3000
              | image_tag:
                loading: slide_loading,
                fetchpriority: slide_priority,
                sizes: '100vw',
                widths: '750, 1100, 1500, 2000, 2400, 3000',
                class: 'hero-slider__image',
                alt: block.settings.image.alt
            }}
          {%- endif -%}
        </div>

        <div class="hero-slider__content">
          <h2 class="hero-slider__heading">{{ block.settings.heading }}</h2>

          <p class="hero-slider__description">{{ block.settings.description }}</p>

          {%- if block.settings.cta_label != blank -%}
            <a class="hero-slider__cta" href="{{ block.settings.cta_url | default: '#' }}">
              <span class="hero-slider__cta-label">{{ block.settings.cta_label }}</span>
              <span class="hero-slider__cta-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
                  <path d="M4 12h15m0 0-6-6m6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- comment -%} ===== PROMO CARDS: bottom-left, above the USP bar ===== {%- endcomment -%}
  {%- if promos.size > 0 -%}
    <div class="hero-slider__promos">
      {%- for block in promos -%}
        <a
          class="hero-slider__promo"
          href="{{ block.settings.url | default: '#' }}"
          {{ block.shopify_attributes }}
        >
          <span class="hero-slider__promo-media">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 600
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 750px) 160px, 45vw',
                  widths: '160, 320, 480, 600',
                  class: 'hero-slider__promo-image',
                  alt: ''
              }}
            {%- endif -%}
          </span>
          <span class="hero-slider__promo-label">{{ block.settings.label }}</span>
          <span class="hero-slider__promo-arrow" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg">
              <path d="M4 12h15m0 0-6-6m6 6-6 6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}
  </div>

  {%- comment -%} ===== PAGINATION: far-right edge (desktop) / bottom row (mobile). One control per slide ===== {%- endcomment -%}
  {%- if slides.size > 1 -%}
    <div
      class="hero-slider__pagination"
      role="group"
      aria-label="{{ section.settings.pagination_label | default: 'Select a slide to display' }}"
    >
      {%- for block in slides -%}
        <button
          type="button"
          class="hero-slider__dot{% if forloop.first %} hero-slider__dot--active{% endif %}"
          aria-label="{{ forloop.index }} / {{ slides.size }}"
          {%- if forloop.first %} aria-current="true"{% endif %}
        >
          <span class="hero-slider__dot-fill" aria-hidden="true"></span>
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- comment -%} ===== USP BAR: very bottom of the hero wrapper ===== {%- endcomment -%}
  {%- if usps.size > 0 -%}
    <ul class="hero-slider__usp">
      {%- for block in usps -%}
        <li class="hero-slider__usp-item" {{ block.shopify_attributes }}>
          <span class="hero-slider__usp-icon" aria-hidden="true">
            {{ block.settings.icon }}
          </span>
          <span class="hero-slider__usp-text">{{ block.settings.text }}</span>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</section>

{%- comment -%} Customizer-driven heading size — strictly scoped to this section instance {%- endcomment -%}
{% style %}
  #shopify-section-{{ section.id }} .hero-slider__heading {
    font-size: {{ section.settings.heading_size_mobile | default: 44 }}px;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .hero-slider__heading {
      font-size: {{ section.settings.heading_size_desktop | default: 120 }}px;
    }
  }
{% endstyle %}

{% stylesheet %}
  /* ===================================================================
     Hero Slider — STEP 2 CSS · Part 1 of 2
     foundation · media + overlay · slide/content layout · typography · CTA
     Mobile-first. Scoped to .hero-slider (BEM). (Promos/pagination/USP = Part 2)
     =================================================================== */

  .hero-slider {
    --hs-text: #ffffff;
    --hs-accent: #e0431f;
    --hs-inline: 1.25rem;
    --hs-header-offset: var(--header-height, 60px);

    position: relative;
    isolation: isolate;
    min-height: 100svh;
    overflow: hidden;
    color: var(--hs-text);
    background-color: #2a0f12;
  }

  /* ---------- Left content column: heading/desc/CTA + promos in normal flow ---------- */
  .hero-slider__main {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: safe center;
    gap: 3rem; /* space between the text/CTA and the promo cards */
    width: 100%;
    max-width: 36rem;
    min-height: 100svh;
    padding-block-start: calc(var(--hs-header-offset) + 2rem);
    padding-block-end: 7rem; /* clear the pagination row (USP hidden on mobile) */
    padding-inline: var(--hs-inline);
  }

  /* ---------- Slides: stacked layers, cross-fade (JS toggles --active in Step 3) ---------- */
  .hero-slider__slides {
    display: grid; /* stack all slides in one cell so the column has real height */
    width: 100%;
  }

  .hero-slider__slide {
    grid-area: 1 / 1;
    isolation: isolate;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease, visibility 0s linear 0.6s;
  }

  .hero-slider__slide--active {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.6s ease;
  }

  /* ---------- Media + readability overlay ---------- */
  .hero-slider__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-slider__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 72% center;
  }

  .hero-slider__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 72% center;
    display: block;
  }

  .hero-slider__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.3) 38%, rgba(0, 0, 0, 0) 68%),
      linear-gradient(0deg, rgba(0, 0, 0, 0.55) 0%, rgba(0, 0, 0, 0) 38%);
  }

  /* ---------- Content column ---------- */
  .hero-slider__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.25rem;
    width: 100%;
  }

  /* ---------- Heading (massive H2) ---------- */
  .hero-slider__heading {
    margin: 0;
    color: var(--hs-text);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    font-size: clamp(2.75rem, 11vw, 5rem);
  }

  .hero-slider__heading::after {
    content: '';
    display: block;
    width: 4.5rem;
    height: 3px;
    margin-block-start: 1.25rem;
    background: var(--hs-accent);
  }

  /* ---------- Description ---------- */
  .hero-slider__description {
    margin: 0;
    max-width: 34ch;
    font-size: 1rem;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.85);
  }

  /* ---------- CTA: white bg · black text · arrow ---------- */
  .hero-slider__cta {
    display: inline-flex;
    align-items: center;
    gap: 1.25rem;
    margin-block-start: 0.5rem;
    padding: 1rem 1.5rem;
    border-radius: 8px;
    background: #ffffff;
    color: #111111;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  .hero-slider__cta-icon {
    display: inline-flex;
    transition: transform 0.25s ease;
  }

  @media (hover: hover) {
    .hero-slider__cta:hover {
      background: #f1efec;
      transform: translateY(-2px);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.25);
    }

    .hero-slider__cta:hover .hero-slider__cta-icon {
      transform: translateX(5px);
    }
  }

  /* ===================== DESKTOP (≥ 750px): scale type + reserve bottom space ===================== */
  @media screen and (min-width: 750px) {
    .hero-slider {
      --hs-inline: clamp(2.5rem, 5vw, 5rem);
      min-height: 100vh;
    }

    .hero-slider__main {
      max-width: 44rem;
      min-height: 100vh;
      padding-block-end: 8rem; /* desktop: only the USP bar sits at the bottom */
    }

    .hero-slider__content {
      gap: 1.75rem;
    }

    .hero-slider__heading {
      font-size: clamp(5rem, 8.6vw, 8.5rem);
    }

    .hero-slider__heading::after {
      width: 5.5rem;
      margin-block-start: 1.75rem;
    }

    .hero-slider__description {
      font-size: 1.0625rem;
    }
  }
  /* ===================================================================
     Hero Slider — STEP 2 CSS · Part 2 of 2
     Promo cards · Pagination · USP bar  (mobile-first base + desktop overrides)
     =================================================================== */

  /* Hide scrollbars on the mobile scroll rows */
  .hero-slider__promos,
  .hero-slider__usp {
    scrollbar-width: none;
  }

  .hero-slider__promos::-webkit-scrollbar,
  .hero-slider__usp::-webkit-scrollbar {
    display: none;
  }

  /* (Mobile bottom safe-area now lives on .hero-slider__main) */

  /* ----------------------------- PROMO CARDS ----------------------------- */
  /* Mobile base: horizontal scroll-snap row, above pagination + USP */
  /* Mobile: two large, touch-friendly cards side by side */
  .hero-slider__promos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.75rem;
    width: 100%;
  }

  .hero-slider__promo {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 12px;
    overflow: hidden;
    isolation: isolate;
    color: #ffffff;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .hero-slider__promo-media {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-slider__promo-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* readability gradient per card */
  .hero-slider__promo::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(0deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0) 62%);
  }

  .hero-slider__promo-label {
    position: absolute;
    z-index: 1;
    inset-inline-start: 0.85rem;
    inset-block-end: 0.7rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .hero-slider__promo-arrow {
    position: absolute;
    z-index: 1;
    inset-inline-end: 0.7rem;
    inset-block-end: 0.6rem;
    display: inline-flex;
    transition: transform 0.3s ease;
  }

  @media (hover: hover) {
    .hero-slider__promo:hover {
      transform: translateY(-3px);
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.35);
    }

    .hero-slider__promo:hover .hero-slider__promo-arrow {
      transform: translateX(4px);
    }
  }

  /* ----------------------------- PAGINATION ----------------------------- */
  /* Mobile base: horizontal row above the USP bar */
  .hero-slider__pagination {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 3.5rem;
    z-index: 2;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
  }

  .hero-slider__dot {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border: 0;
    background: transparent;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .hero-slider__dot-fill {
    display: block;
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.45);
    transition: width 0.3s ease, height 0.3s ease, background-color 0.3s ease;
  }

  .hero-slider__dot--active .hero-slider__dot-fill {
    width: 26px;
    height: 4px;
    background: #ffffff;
  }

  .hero-slider__dot:focus-visible {
    outline: 2px solid #ffffff;
    outline-offset: 2px;
    border-radius: 4px;
  }

  @media (hover: hover) {
    .hero-slider__dot:hover .hero-slider__dot-fill {
      background: #ffffff;
    }
  }

  /* ----------------------------- USP BAR ----------------------------- */
  /* Mobile base: full-width horizontal scroll row at the very bottom */
  .hero-slider__usp {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    margin: 0;
    padding: 0.85rem var(--hs-inline);
    list-style: none;
    display: none; /* hidden on mobile per client feedback */
    flex-wrap: nowrap;
    align-items: center;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
  }

  .hero-slider__usp-item {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    scroll-snap-align: start;
  }

  .hero-slider__usp-icon {
    display: inline-flex;
    flex: none;
    width: 1.25rem;
    height: 1.25rem;
  }

  .hero-slider__usp-icon > :is(svg, img) {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* =========================== DESKTOP (≥ 750px) =========================== */
  @media screen and (min-width: 750px) {
    /* Promo cards → larger, no scroll (they sit in the left-column flow) */
    .hero-slider__promos {
      display: flex;
      gap: 1rem;
      overflow: visible;
    }

    .hero-slider__promo {
      width: 13rem;
      aspect-ratio: 16 / 10;
      border-radius: 8px;
    }

    .hero-slider__promo-label {
      font-size: 0.75rem;
    }

    /* Pagination → far-right edge, vertically centered, vertical stack */
    .hero-slider__pagination {
      left: auto;
      right: clamp(1rem, 2vw, 1.75rem);
      bottom: auto;
      top: 50%;
      transform: translateY(-50%);
      flex-direction: column;
      gap: 0.85rem;
    }

    .hero-slider__dot--active .hero-slider__dot-fill {
      width: 4px;
      height: 28px; /* vertical active bar */
    }

    /* USP bar → evenly spaced full-width row with dividers */
    .hero-slider__usp {
      display: flex; /* shown again on desktop */
      gap: 0;
      overflow: visible;
      padding-block: 1.25rem;
      border-top: 1px solid rgba(255, 255, 255, 0.14);
    }

    .hero-slider__usp-item {
      flex: 1 1 0;
      justify-content: center;
      font-size: 0.8125rem;
    }

    .hero-slider__usp-item + .hero-slider__usp-item {
      border-inline-start: 1px solid rgba(255, 255, 255, 0.18);
    }
  }
{% endstylesheet %}

<script>
  (function () {
    'use strict';

    /* Re-exec guard: a section can be re-injected by the Customizer (running this
       inline script again) or appear multiple times. If we've already bootstrapped,
       just (re)initialise instances and bail so document listeners stay singular. */
    if (window.HeroSliderController) {
      window.HeroSliderController.initAll();
      return;
    }

    var SEL = {
      root: '.hero-slider',
      track: '.hero-slider__slides',
      slide: '.hero-slider__slide',
      slideActive: 'hero-slider__slide--active',
      dot: '.hero-slider__dot',
      dotActive: 'hero-slider__dot--active'
    };
    var SWIPE_THRESHOLD = 40; /* px */

    /** Controls one .hero-slider instance. */
    class HeroSlider {
      constructor(root) {
        this.root = root;
        this.track = root.querySelector(SEL.track);
        this.slides = Array.from(root.querySelectorAll(SEL.slide));
        this.dots = Array.from(root.querySelectorAll(SEL.dot));
        this.ac = new AbortController();   /* one abort() removes every listener */
        this.timer = null;                 /* autoplay interval id */
        this.pointerStartX = null;
        this.reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        var ms = parseInt(root.dataset.autoplayInterval || '0', 10);
        this.autoplayMs = isNaN(ms) ? 0 : ms;
        var found = this.slides.findIndex(function (s) { return s.classList.contains(SEL.slideActive); });
        this.index = found < 0 ? 0 : found;
      }

      init() {
        if (this.slides.length === 0) return;          /* guard: nothing to drive */
        var signal = this.ac.signal;
        var self = this;

        this.render(this.index);

        /* Pagination dots */
        this.dots.forEach(function (dot, i) {
          dot.addEventListener('click', function () { self.goTo(i); self.restart(); }, { signal: signal });
        });

        /* Keyboard — only acts while focus is within the slider (no global hijack) */
        this.root.addEventListener('keydown', this.onKeydown, { signal: signal });

        /* Touch / pointer swipe */
        if (this.track) {
          this.track.addEventListener('pointerdown', this.onPointerDown, { signal: signal });
          this.track.addEventListener('pointerup', this.onPointerUp, { signal: signal });
          this.track.addEventListener('pointercancel', this.onPointerCancel, { signal: signal });
        }

        /* Pause autoplay on interaction */
        this.root.addEventListener('mouseenter', this.stop, { signal: signal });
        this.root.addEventListener('mouseleave', this.start, { signal: signal });
        this.root.addEventListener('focusin', this.stop, { signal: signal });
        this.root.addEventListener('focusout', this.start, { signal: signal });

        this.start();
      }

      onKeydown = (e) => {
        if (e.key === 'ArrowLeft') { e.preventDefault(); this.prev(); this.restart(); }
        else if (e.key === 'ArrowRight') { e.preventDefault(); this.next(); this.restart(); }
      };

      onPointerDown = (e) => {
        if (e.pointerType === 'mouse' && e.button !== 0) return;
        this.pointerStartX = e.clientX;
      };

      onPointerUp = (e) => {
        if (this.pointerStartX === null) return;
        var delta = e.clientX - this.pointerStartX;
        this.pointerStartX = null;
        if (Math.abs(delta) < SWIPE_THRESHOLD) return;
        if (delta < 0) this.next(); else this.prev();
        this.restart();
      };

      onPointerCancel = () => { this.pointerStartX = null; };

      goTo(i) {
        var n = this.slides.length;
        if (n === 0) return;
        this.index = ((i % n) + n) % n;   /* wrap around */
        this.render(this.index);
      }
      next() { this.goTo(this.index + 1); }
      prev() { this.goTo(this.index - 1); }

      /* State + a11y sync. The fade itself is CSS (.hero-slider__slide opacity transition). */
      render(i) {
        var autoplaying = this.timer !== null;
        this.slides.forEach(function (slide, idx) {
          var active = idx === i;
          slide.classList.toggle(SEL.slideActive, active);
          slide.setAttribute('aria-hidden', active ? 'false' : 'true');
          if ('inert' in slide) slide.inert = !active;   /* keep off-screen content out of tab order */
        });
        this.dots.forEach(function (dot, idx) {
          var active = idx === i;
          dot.classList.toggle(SEL.dotActive, active);
          if (active) dot.setAttribute('aria-current', 'true');
          else dot.removeAttribute('aria-current');
        });
        if (this.track) {
          /* Announce on manual change; silence while auto-rotating (APG guidance) */
          this.track.setAttribute('aria-live', autoplaying ? 'off' : 'polite');
        }
      }

      /* ---- Autoplay (off unless data-autoplay-interval > 0; set via schema in Step 4) ---- */
      start = () => {
        if (this.autoplayMs <= 0 || this.slides.length < 2 || this.reducedMotion) return;
        if (this.timer !== null) return;
        var self = this;
        this.timer = window.setInterval(function () { self.next(); }, this.autoplayMs);
        if (this.track) this.track.setAttribute('aria-live', 'off');
      };

      stop = () => {
        if (this.timer !== null) { window.clearInterval(this.timer); this.timer = null; }
        if (this.track) this.track.setAttribute('aria-live', 'polite');
      };

      restart = () => { this.stop(); this.start(); };

      /* Flawless teardown: clear interval + remove EVERY listener via the AbortController */
      destroy() {
        this.stop();
        this.ac.abort();
      }
    }

    /* ---- Registry + lifecycle ---- */
    var instances = new Map();   /* rootEl -> HeroSlider */

    function initRoot(root) {
      if (!root || instances.has(root)) return;
      var inst = new HeroSlider(root);
      instances.set(root, inst);
      inst.init();
    }

    function destroyRoot(root) {
      var inst = instances.get(root);
      if (!inst) return;
      inst.destroy();
      instances.delete(root);
    }

    /* Clean up instances whose root was removed by a section re-render */
    function sweepDetached() {
      instances.forEach(function (inst, root) {
        if (!root.isConnected) { inst.destroy(); instances.delete(root); }
      });
    }

    function initAll(scope) {
      sweepDetached();
      (scope || document).querySelectorAll(SEL.root).forEach(initRoot);
    }

    /* Initial page load */
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () { initAll(); }, { once: true });
    } else {
      initAll();
    }

    /* Shopify Theme Editor lifecycle */
    document.addEventListener('shopify:section:load', function (e) {
      sweepDetached();
      if (e.target && e.target.querySelectorAll) {
        e.target.querySelectorAll(SEL.root).forEach(initRoot);
      }
    });

    document.addEventListener('shopify:section:unload', function (e) {
      if (e.target && e.target.querySelectorAll) {
        e.target.querySelectorAll(SEL.root).forEach(destroyRoot);
      }
      sweepDetached();
    });

    /* Editor convenience: jump to + pause on the slide whose block is selected */
    document.addEventListener('shopify:block:select', function (e) {
      var root = e.target.closest ? e.target.closest(SEL.root) : null;
      if (!root) return;
      var inst = instances.get(root);
      if (!inst) return;
      inst.stop();
      var slide = e.target.closest(SEL.slide);
      if (slide) {
        var idx = inst.slides.indexOf(slide);
        if (idx >= 0) inst.goTo(idx);
      }
    });
    document.addEventListener('shopify:block:deselect', function (e) {
      var root = e.target.closest ? e.target.closest(SEL.root) : null;
      if (root && instances.has(root)) instances.get(root).start();
    });

    /* Pause autoplay when the tab is hidden (single global listener) */
    document.addEventListener('visibilitychange', function () {
      instances.forEach(function (inst) {
        if (document.hidden) inst.stop(); else inst.start();
      });
    });

    window.HeroSliderController = { initAll: initAll, instances: instances };
  })();
</script>

