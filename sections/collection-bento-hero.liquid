{%- comment -%}
  Collection Bento Hero — sections/collection-bento-hero.liquid
  Catalog landing hero: a two-column intro (heading + buttons / paragraph) over a
  4-card bento grid. Desktop = left tall card, a stacked middle column, right tall
  card. Mobile = intro stacks and the cards become a single full-width column.
  Blocks (max 4) drive the cards: image + link + title. BEM styles + schema below.
{%- endcomment -%}

{%- capture arrow_ne -%}<svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M7 17 17 7"/><path d="M8 7h9v9"/></svg>{%- endcapture -%}

<section
  class="collection-bento color-{{ section.settings.color_scheme }}"
  style="--cbh-radius: {{ section.settings.card_corner_radius | default: 20 }}px; --cbh-overlay: {{ section.settings.overlay_opacity | default: 36 | divided_by: 100.0 }};"
>
  <div class="collection-bento__intro">
    <div class="collection-bento__intro-main">
      {%- if section.settings.heading != blank -%}
        <h1 class="collection-bento__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.button_1_label != blank or section.settings.button_2_label != blank -%}
        <div class="collection-bento__actions">
          {%- if section.settings.button_1_label != blank -%}
            <a class="collection-bento__btn collection-bento__btn--solid" href="{{ section.settings.button_1_link | default: '#' }}">
              <span>{{ section.settings.button_1_label }}</span>{{ arrow_ne }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_2_label != blank -%}
            <a class="collection-bento__btn collection-bento__btn--outline" href="{{ section.settings.button_2_link | default: '#' }}">
              <span>{{ section.settings.button_2_label }}</span>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.paragraph != blank -%}
      <div class="collection-bento__intro-aside">{{ section.settings.paragraph }}</div>
    {%- endif -%}
  </div>

  {%- if section.blocks.size > 0 -%}
    <div class="collection-bento__grid">
      {%- for block in section.blocks -%}
        <a
          class="collection-bento__card collection-bento__card--{{ forloop.index }}"
          href="{{ block.settings.link | default: '#' }}"
          {{ block.shopify_attributes }}
        >
          <div class="collection-bento__media">
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 1400
                | image_tag:
                  loading: 'lazy',
                  sizes: '(min-width: 750px) 40vw, 100vw',
                  widths: '420, 640, 860, 1100, 1400',
                  class: 'collection-bento__image',
                  alt: block.settings.text
              }}
            {%- else -%}
              {%- capture phn -%}{% cycle 'collection-1', 'collection-2', 'lifestyle-1', 'lifestyle-2' %}{%- endcapture -%}
              {{ phn | placeholder_svg_tag: 'collection-bento__image collection-bento__image--ph' }}
            {%- endif -%}
          </div>

          <span class="collection-bento__card-arrow" aria-hidden="true">{{ arrow_ne }}</span>

          {%- if block.settings.text != blank -%}
            <span class="collection-bento__card-title">{{ block.settings.text }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .collection-bento {
    --cbh-gutter: clamp(1rem, 4vw, 4rem);
    --cbh-gap: clamp(0.6rem, 1.2vw, 1rem);

    background-color: var(--color-background, #edebe7);
    color: var(--color-foreground, #1a1a1a);
    padding-block: clamp(2rem, 5vw, 4rem);
    padding-inline: var(--cbh-gutter);
  }

  /* ---------- Intro: heading + buttons / paragraph ---------- */
  .collection-bento__intro {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-block-end: clamp(1.5rem, 3vw, 2.75rem);
  }

  .collection-bento__heading {
    margin: 0;
    max-width: 18ch;
    font-weight: 600;
    line-height: 1.08;
    letter-spacing: -0.01em;
    font-size: clamp(2rem, 5vw, 3.5rem);
  }

  .collection-bento__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-block-start: clamp(1.25rem, 2.5vw, 2rem);
  }

  .collection-bento__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.9rem 1.5rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.25s ease, background-color 0.25s ease, color 0.25s ease;
  }
  .collection-bento__btn svg { flex: none; }

  .collection-bento__btn--solid {
    background: var(--color-foreground, #1a1a1a);
    color: var(--color-background, #fff);
    border: 1px solid var(--color-foreground, #1a1a1a);
  }
  .collection-bento__btn--outline {
    background: transparent;
    color: inherit;
    border: 1px solid rgb(var(--color-foreground-rgb, 26 26 26) / 0.35);
  }

  @media (hover: hover) {
    .collection-bento__btn:hover { transform: translateY(-2px); }
    .collection-bento__btn--outline:hover { border-color: var(--color-foreground, #1a1a1a); }
  }

  .collection-bento__intro-aside {
    font-size: 1rem;
    line-height: 1.65;
    color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.7);
    max-width: 34ch;
  }
  .collection-bento__intro-aside > :first-child { margin-block-start: 0; }
  .collection-bento__intro-aside > :last-child { margin-block-end: 0; }

  /* ---------- Bento grid (mobile = single stacked column) ---------- */
  .collection-bento__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--cbh-gap);
  }

  .collection-bento__card {
    position: relative;
    display: block;
    min-height: 15rem;
    border-radius: var(--cbh-radius, 20px);
    overflow: hidden;
    isolation: isolate;
    color: #fff;
    text-decoration: none;
    background-color: #262626;
  }

  .collection-bento__media {
    position: absolute;
    inset: 0;
    z-index: -2;
  }

  .collection-bento__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .collection-bento__image--ph { object-fit: cover; opacity: 0.55; }

  /* subtle dark overlay, deeper at the bottom for the title */
  .collection-bento__card::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, calc(var(--cbh-overlay, 0.36) * 0.4)) 0%,
      rgba(0, 0, 0, 0) 34%,
      rgba(0, 0, 0, calc(var(--cbh-overlay, 0.36) * 1.45)) 100%
    );
  }

  .collection-bento__card-title {
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 2;
    padding: clamp(1.1rem, 2vw, 1.75rem);
    font-size: clamp(1.4rem, 2.4vw, 2.1rem);
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.01em;
    text-shadow: 0 1px 12px rgba(0, 0, 0, 0.25);
  }

  .collection-bento__card-arrow {
    position: absolute;
    top: clamp(0.75rem, 1.5vw, 1.1rem);
    right: clamp(0.75rem, 1.5vw, 1.1rem);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    color: #111;
    transition: transform 0.3s ease, background-color 0.3s ease;
  }

  @media (hover: hover) {
    .collection-bento__card:hover .collection-bento__image { transform: scale(1.06); }
    .collection-bento__card:hover .collection-bento__card-arrow {
      transform: translate(2px, -2px);
      background: #fff;
    }
  }

  .collection-bento__card:focus-visible {
    outline: 2px solid var(--color-foreground, #1a1a1a);
    outline-offset: 3px;
  }

  /* ---------- Desktop: intro 2-up + bento areas ---------- */
  @media screen and (min-width: 750px) {
    .collection-bento__intro {
      grid-template-columns: 1.6fr 1fr;
      align-items: start;
      gap: clamp(2rem, 5vw, 4.5rem);
    }
    .collection-bento__intro-aside {
      padding-block-start: 0.5rem;
      justify-self: end;
    }

    .collection-bento__grid {
      grid-template-columns: 1.5fr 1fr 1fr;
      grid-template-rows: repeat(2, clamp(10rem, 14vw, 13rem));
      grid-template-areas:
        'a b d'
        'a c d';
    }
    .collection-bento__card { min-height: 0; }
    .collection-bento__card--1 { grid-area: a; }
    .collection-bento__card--2 { grid-area: b; }
    .collection-bento__card--3 { grid-area: c; }
    .collection-bento__card--4 { grid-area: d; }
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-bento__image,
    .collection-bento__btn,
    .collection-bento__card-arrow {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Collection bento hero",
  "class": "collection-bento-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "max_blocks": 4,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Intro"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Движение с лекота, сила с всяка стъпка."
    },
    {
      "type": "richtext",
      "id": "paragraph",
      "label": "Paragraph",
      "default": "<p>Активно облекло, създадено за комфорт, представяне и увереност – навсякъде, където те отведе денят.</p>"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_1_label",
      "label": "Button 1 label (solid)",
      "default": "Пазарувай сега"
    },
    {
      "type": "url",
      "id": "button_1_link",
      "label": "Button 1 link"
    },
    {
      "type": "text",
      "id": "button_2_label",
      "label": "Button 2 label (outline)",
      "default": "Колекция 2024"
    },
    {
      "type": "url",
      "id": "button_2_link",
      "label": "Button 2 link"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "range",
      "id": "card_corner_radius",
      "label": "Card corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "%",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Bento card",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Background image" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "text", "label": "Title", "default": "Колекция" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection bento hero",
      "blocks": [
        { "type": "card", "settings": { "text": "Дамска колекция" } },
        { "type": "card", "settings": { "text": "Мъжка колекция" } },
        { "type": "card", "settings": { "text": "Нова колекция" } },
        { "type": "card", "settings": { "text": "Аксесоари" } }
      ]
    }
  ]
}
{% endschema %}
