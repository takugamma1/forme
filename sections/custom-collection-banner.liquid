{%- comment -%}
  Custom Collection Banner — sections/custom-collection-banner.liquid
  Full-width rounded image banner with a middle-left (bottom-left on mobile)
  heading overlay. Separate desktop / mobile images via <picture>. Optional
  link wraps the whole banner. BEM styles + schema below.
{%- endcomment -%}

{%- capture banner_inner -%}
  <picture class="collection-banner__picture">
    {%- if section.settings.image_mobile != blank -%}
      <source
        media="(max-width: 749px)"
        srcset="{{ section.settings.image_mobile | image_url: width: 1000 }} 1x, {{ section.settings.image_mobile | image_url: width: 1500 }} 1.5x"
      >
    {%- endif -%}
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2200
        | image_tag:
          loading: 'lazy',
          sizes: '100vw',
          widths: '800, 1200, 1600, 2000, 2200',
          class: 'collection-banner__image',
          alt: section.settings.heading
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'collection-banner__image collection-banner__image--ph' }}
    {%- endif -%}
  </picture>
  <div class="collection-banner__overlay">
    {%- if section.settings.heading != blank -%}
      <h2 class="collection-banner__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
  </div>
{%- endcapture -%}

<section
  class="collection-banner color-{{ section.settings.color_scheme }}"
  style="--cban-radius: {{ section.settings.corner_radius | default: 20 }}px;"
>
  {%- if section.settings.link != blank -%}
    <a class="collection-banner__inner" href="{{ section.settings.link }}">{{ banner_inner }}</a>
  {%- else -%}
    <div class="collection-banner__inner">{{ banner_inner }}</div>
  {%- endif -%}
</section>

{% stylesheet %}
  .collection-banner {
    background-color: var(--color-background, #edebe7);
    padding-block: clamp(2rem, 3vw, 2.5rem);
    padding-inline: clamp(1rem, 4vw, 4rem);
  }

  .collection-banner__inner {
    position: relative;
    display: block;
    aspect-ratio: 16 / 5;
    border-radius: var(--cban-radius, 20px);
    overflow: hidden;
    isolation: isolate;
    color: #ece7de;
    text-decoration: none;
  }

  .collection-banner__picture {
    position: absolute;
    inset: 0;
    z-index: -2;
    display: block;
  }

  .collection-banner__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .collection-banner__image--ph { opacity: 0.6; }

  /* subtle dark gradient on the left so the heading stays legible */
  .collection-banner__inner::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(90deg, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.18) 36%, rgba(0, 0, 0, 0) 62%);
  }

  .collection-banner__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    padding-inline: clamp(1.5rem, 6vw, 5rem);
  }

  .collection-banner__heading {
    margin: 0;
    max-width: 12ch;
    font-weight: 400;
    line-height: 1.15;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-size: clamp(1.6rem, 4vw, 3rem);
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.3);
  }

  @media (hover: hover) {
    a.collection-banner__inner:hover .collection-banner__image { transform: scale(1.04); }
  }

  @media screen and (max-width: 749px) {
    .collection-banner__inner { aspect-ratio: 4 / 5; }
    /* heading drops to the bottom on mobile — darken the bottom for legibility */
    .collection-banner__inner::after {
      background: linear-gradient(to top, rgba(0, 0, 0, 0.58) 0%, rgba(0, 0, 0, 0.18) 46%, rgba(0, 0, 0, 0) 78%);
    }
    .collection-banner__overlay {
      align-items: flex-end;
      padding-block: clamp(1.5rem, 7vw, 2.5rem);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .collection-banner__image { transition: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom collection banner",
  "class": "custom-collection-banner-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile image",
      "info": "Optional. Falls back to the desktop image."
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Ice Blue Collection"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "range",
      "id": "corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Custom collection banner"
    }
  ]
}
{% endschema %}
