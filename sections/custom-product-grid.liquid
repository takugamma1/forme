{%- comment -%}
  Custom Product Grid — sections/custom-product-grid.liquid
  Centred uppercase heading, a 4-up product grid (2-up on mobile) pulling N
  products from a collection picker, and a centred underlined "view all" link.
  Cards: rounded light-grey image tile + left-aligned title (regular) and price
  (bold). Falls back to styled placeholders when no collection is set.
  BEM styles + schema below.
{%- endcomment -%}

{%- assign coll = section.settings.collection -%}
{%- assign count = section.settings.products_to_show | default: 4 -%}

{%- capture arrow_r -%}<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M5 12h14"/><path d="m13 6 6 6-6 6"/></svg>{%- endcapture -%}

<section class="product-grid color-{{ section.settings.color_scheme }}">
  {%- if section.settings.heading != blank -%}
    <h2 class="product-grid__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <ul class="product-grid__grid" role="list">
    {%- if coll != blank and coll.products.size > 0 -%}
      {%- for product in coll.products limit: count -%}
        <li class="product-grid__item">
          <a class="product-grid__card" href="{{ product.url }}">
            <div class="product-grid__media">
              {%- if product.featured_image != blank -%}
                {{
                  product.featured_image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 750px) 23vw, 46vw',
                    widths: '250, 400, 550, 700, 800',
                    class: 'product-grid__image',
                    alt: product.title
                }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'product-grid__image product-grid__image--ph' }}
              {%- endif -%}
            </div>
            <div class="product-grid__info">
              <span class="product-grid__title">{{ product.title }}</span>
              <span class="product-grid__price">{{ product.price | money }}</span>
            </div>
          </a>
        </li>
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..count) -%}
        <li class="product-grid__item">
          <div class="product-grid__card">
            <div class="product-grid__media">
              {%- capture phn -%}{% cycle 'ph': 'product-1', 'product-2', 'product-3', 'product-4' %}{%- endcapture -%}
              {{ phn | placeholder_svg_tag: 'product-grid__image product-grid__image--ph' }}
            </div>
            <div class="product-grid__info">
              <span class="product-grid__title">{%- cycle 'pt': 'Спортно бюстие – Elevate', 'Клин – Power', 'Топ – Motion', 'Чанта – Core' -%}</span>
              <span class="product-grid__price">{%- cycle 'pp': '79.00 лв.', '89.00 лв.', '69.00 лв.', '109.00 лв.' -%}</span>
            </div>
          </div>
        </li>
      {%- endfor -%}
    {%- endif -%}
  </ul>

  {%- if section.settings.link_label != blank -%}
    <div class="product-grid__footer">
      <a class="product-grid__view-all" href="{{ section.settings.link_url | default: '#' }}">
        <span>{{ section.settings.link_label }}</span>{{ arrow_r }}
      </a>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .product-grid {
    --pg-gutter: clamp(1rem, 4vw, 4rem);

    background-color: var(--color-background, #edebe7);
    color: var(--color-foreground, #1a1a1a);
    padding-block: clamp(2.5rem, 5vw, 4.5rem);
    padding-inline: var(--pg-gutter);
  }

  .product-grid__heading {
    margin: 0 auto clamp(2rem, 4vw, 3rem);
    max-width: 40rem;
    text-align: center;
    text-transform: uppercase;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: 0.04em;
    font-size: clamp(1rem, 2vw, 1.35rem);
  }

  /* ---------- Grid: 2-up mobile, 4-up desktop ---------- */
  .product-grid__grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 2.5vw, 1.75rem) clamp(0.75rem, 2vw, 1.5rem);
  }

  .product-grid__item { min-width: 0; }

  .product-grid__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  /* ---------- Image tile: rounded, light-grey backdrop ---------- */
  .product-grid__media {
    position: relative;
    aspect-ratio: 3 / 4;
    border-radius: 14px;
    overflow: hidden;
    background-color: #f0efec;
  }

  .product-grid__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .product-grid__image--ph { object-fit: cover; opacity: 0.5; }

  @media (hover: hover) {
    a.product-grid__card:hover .product-grid__image { transform: scale(1.04); }
  }

  /* ---------- Info: left-aligned title + bold price ---------- */
  .product-grid__info {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-block-start: 0.85rem;
    text-align: left;
  }

  .product-grid__title {
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.3;
    color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.8);
  }

  .product-grid__price {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-foreground, #1a1a1a);
  }

  /* ---------- Bottom view-all link ---------- */
  .product-grid__footer {
    margin-block-start: clamp(2rem, 4vw, 3rem);
    text-align: center;
  }

  .product-grid__view-all {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: inherit;
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    text-decoration: underline;
    text-underline-offset: 6px;
    text-decoration-thickness: 1.5px;
    transition: opacity 0.2s ease;
  }
  .product-grid__view-all svg { flex: none; transition: transform 0.25s ease; }
  @media (hover: hover) {
    .product-grid__view-all:hover { opacity: 0.65; }
    .product-grid__view-all:hover svg { transform: translateX(4px); }
  }

  /* ---------- Desktop: 4-up ---------- */
  @media screen and (min-width: 750px) {
    .product-grid__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-grid__image,
    .product-grid__view-all svg {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom product grid",
  "class": "custom-product-grid-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "СЪЗДАДЕНИ ЗА ДВИЖЕНИЕ. ПРОЕКТИРАНИ ЗА ТЕБ."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Bottom link"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link label",
      "default": "Виж всички"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link"
    }
  ],
  "presets": [
    {
      "name": "Custom product grid"
    }
  ]
}
{% endschema %}
