{%- comment -%}
  Custom Instagram Feed — sections/custom-instagram-feed.liquid
  Two-column band: left (~1/3) holds the tag / light heading / subtext / handle
  link; right (~2/3) is a single row of 4 square, sharp-cornered images. Stacks
  on mobile (text over a 2x2 image grid). All text, the handle/link and the 4
  images are editable. BEM styles + schema below.
{%- endcomment -%}

{%- capture ig_icon -%}<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.2" cy="6.8" r="1.1" fill="currentColor" stroke="none"/></svg>{%- endcapture -%}
{%- capture arrow_r -%}<svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M4 12h15"/><path d="m13 6 6 6-6 6"/></svg>{%- endcapture -%}

<section class="ig-feed color-{{ section.settings.color_scheme }}">
  <div class="ig-feed__inner">
    <div class="ig-feed__text">
      {%- if section.settings.top_tag != blank -%}
        <p class="ig-feed__tag">{{ section.settings.top_tag }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ig-feed__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      <span class="ig-feed__rule" aria-hidden="true"></span>
      {%- if section.settings.subtext != blank -%}
        <p class="ig-feed__subtext">{{ section.settings.subtext }}</p>
      {%- endif -%}
      {%- if section.settings.handle != blank -%}
        <a class="ig-feed__link" href="{{ section.settings.link | default: '#' }}"{% if section.settings.link != blank %} target="_blank" rel="noopener noreferrer"{% endif %}>
          <span class="ig-feed__link-icon" aria-hidden="true">{{ ig_icon }}</span>
          <span class="ig-feed__handle">{{ section.settings.handle }}</span>
          <span class="ig-feed__link-arrow" aria-hidden="true">{{ arrow_r }}</span>
        </a>
      {%- endif -%}
    </div>

    <div class="ig-feed__grid">
      {%- for n in (1..4) -%}
        {%- assign key = 'image_' | append: n -%}
        {%- assign img = section.settings[key] -%}
        <div class="ig-feed__item">
          {%- if img != blank -%}
            {{
              img
              | image_url: width: 800
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 750px) 17vw, 50vw',
                widths: '250, 400, 550, 800',
                class: 'ig-feed__image',
                alt: section.settings.handle
            }}
          {%- else -%}
            {%- capture phn -%}{% cycle 'igph': 'lifestyle-1', 'lifestyle-2' %}{%- endcapture -%}
            {{ phn | placeholder_svg_tag: 'ig-feed__image ig-feed__image--ph' }}
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .ig-feed {
    --ig-gutter: clamp(1rem, 4vw, 4rem);

    background-color: var(--color-background, #f4f1ec);
    color: var(--color-foreground, #1a1a1a);
    border-top: 1px solid rgb(var(--color-foreground-rgb, 26 26 26) / 0.1);
    padding-block: clamp(2.5rem, 5vw, 4.5rem);
    padding-inline: var(--ig-gutter);
  }

  .ig-feed__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1.75rem, 4vw, 3rem);
    align-items: center;
  }

  /* ---------- Left: text ---------- */
  .ig-feed__tag {
    margin: 0;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.55);
  }
  .ig-feed__heading {
    margin: 0.85rem 0 0;
    font-weight: 300;
    line-height: 1.12;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    font-size: clamp(1.6rem, 3.4vw, 2.5rem);
  }
  .ig-feed__rule {
    display: block;
    width: 2.5rem;
    height: 1px;
    margin: 1.25rem 0;
    background-color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.35);
  }
  .ig-feed__subtext {
    margin: 0;
    max-width: 30ch;
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.7);
  }
  .ig-feed__link {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    margin-block-start: 1.75rem;
    color: inherit;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
  }
  .ig-feed__link svg { flex: none; display: block; }
  .ig-feed__link-arrow { margin-inline-start: 0.5rem; transition: transform 0.25s ease; }
  @media (hover: hover) {
    .ig-feed__link:hover .ig-feed__link-arrow { transform: translateX(5px); }
  }

  /* ---------- Right: 4 square images, sharp corners ---------- */
  .ig-feed__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 4px;
  }
  .ig-feed__item {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.06);
  }
  .ig-feed__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .ig-feed__image--ph { opacity: 0.5; }
  @media (hover: hover) {
    .ig-feed__item:hover .ig-feed__image { transform: scale(1.05); }
  }

  /* ---------- Desktop: 1/3 text + 2/3 image row ---------- */
  @media screen and (min-width: 750px) {
    .ig-feed__inner {
      grid-template-columns: 1fr 2fr;
      gap: clamp(2rem, 4vw, 4rem);
    }
    .ig-feed__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ig-feed__image,
    .ig-feed__link-arrow {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Instagram feed",
  "class": "custom-instagram-feed-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "text",
      "id": "top_tag",
      "label": "Top tag",
      "default": "FOLLOW US"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ПОСЛЕДВАЙ НИ В INSTAGRAM"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Вдъхновение за движение, баланс и активен начин на живот."
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Instagram handle",
      "default": "@kickxbulgaria"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Instagram link"
    },
    {
      "type": "header",
      "content": "Images"
    },
    { "type": "image_picker", "id": "image_1", "label": "Image 1" },
    { "type": "image_picker", "id": "image_2", "label": "Image 2" },
    { "type": "image_picker", "id": "image_3", "label": "Image 3" },
    { "type": "image_picker", "id": "image_4", "label": "Image 4" }
  ],
  "presets": [
    {
      "name": "Instagram feed"
    }
  ]
}
{% endschema %}
