{%- comment -%}
  Footer — sections/footer.liquid (rebuilt, minimalist)
  Top: 3-column split (left menu / centred logo + tagline / right menu).
  Bottom: 3-segment bar (copyright / socials / inspiring text) above a divider.
  Cream, mobile-stacked. Settings-driven (link_lists + text). BEM styles + schema.
{%- endcomment -%}

{%- assign logo = section.settings.logo | default: settings.logo -%}

{%- capture arrow_svg -%}<svg viewBox="0 0 24 24" width="17" height="17" fill="none" stroke="currentColor" stroke-width="1.3" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M5 12h13m0 0-5-5m5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/></svg>{%- endcapture -%}
{%- capture star_svg -%}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path d="M12 0c.6 6 5.4 10.8 11.4 11.4v1.2C17.4 13.2 12.6 18 12 24c-.6-6-5.4-10.8-11.4-11.4v-1.2C6.6 10.8 11.4 6 12 0Z"/></svg>{%- endcapture -%}
{%- capture icon_instagram -%}<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4.2"/><circle cx="17.3" cy="6.7" r="1.1" fill="currentColor" stroke="none"/></svg>{%- endcapture -%}
{%- capture icon_tiktok -%}<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><path d="M13.5 4v8.7a3 3 0 1 1-3-3c.35 0 .68.06 1 .17"/><path d="M13.5 4.2c.3 2.2 2 3.9 4.2 4.2"/></svg>{%- endcapture -%}
{%- capture icon_pinterest -%}<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="9"/><path d="M10.3 18.2 12.2 10c-.4-.6-.5-1.5-.2-2.3.6-1.9 3.6-1.4 3.4.9-.2 1.7-1.7 2.6-3 1.8"/></svg>{%- endcapture -%}
{%- capture icon_email -%}<svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3.5 6.5 8.5 6 8.5-6"/></svg>{%- endcapture -%}

<div class="footer-custom color-{{ section.settings.color_scheme }}" style="--ft-logo-width: {{ section.settings.logo_width | default: 160 }}px;">
  {%- if section.settings.image_left != blank -%}
    <div class="footer-custom__decor footer-custom__decor--left" aria-hidden="true">
      {{ section.settings.image_left | image_url: width: 800 | image_tag: loading: 'lazy', class: 'footer-custom__decor-image', alt: '' }}
    </div>
  {%- endif -%}
  {%- if section.settings.image_right != blank -%}
    <div class="footer-custom__decor footer-custom__decor--right" aria-hidden="true">
      {{ section.settings.image_right | image_url: width: 800 | image_tag: loading: 'lazy', class: 'footer-custom__decor-image', alt: '' }}
    </div>
  {%- endif -%}

  <div class="footer-custom__top">
    {%- if section.settings.menu_left != blank -%}
      <nav class="footer-custom__menu" aria-label="Footer menu 1">
        <ul class="footer-custom__links" role="list">
          {%- for link in section.settings.menu_left.links -%}
            <li>
              <a class="footer-custom__link" href="{{ link.url }}">
                <span>{{ link.title }}</span>{{ arrow_svg }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}

    <div class="footer-custom__center">
      {%- if logo != blank -%}
        <div class="footer-custom__logo">
          {{ logo | image_url: width: 600 | image_tag: loading: 'lazy', class: 'footer-custom__logo-image', alt: shop.name }}
        </div>
      {%- endif -%}
      <span class="footer-custom__star" aria-hidden="true">{{ star_svg }}</span>
      {%- if section.settings.tagline != blank -%}
        <div class="footer-custom__tagline">{{ section.settings.tagline }}</div>
      {%- endif -%}
    </div>

    {%- if section.settings.menu_right != blank -%}
      <nav class="footer-custom__menu" aria-label="Footer menu 2">
        <ul class="footer-custom__links" role="list">
          {%- for link in section.settings.menu_right.links -%}
            <li>
              <a class="footer-custom__link" href="{{ link.url }}">
                <span>{{ link.title }}</span>{{ arrow_svg }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      </nav>
    {%- endif -%}
  </div>

  <div class="footer-custom__bottom">
    {%- if section.settings.copyright != blank -%}
      <div class="footer-custom__copyright">{{ section.settings.copyright }}</div>
    {%- endif -%}

    <div class="footer-custom__socials">
      {%- if section.settings.instagram_link != blank -%}
        <a class="footer-custom__social" href="{{ section.settings.instagram_link }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">{{ icon_instagram }}</a>
      {%- else -%}
        <span class="footer-custom__social" aria-hidden="true">{{ icon_instagram }}</span>
      {%- endif -%}
      {%- if section.settings.tiktok_link != blank -%}
        <a class="footer-custom__social" href="{{ section.settings.tiktok_link }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">{{ icon_tiktok }}</a>
      {%- else -%}
        <span class="footer-custom__social" aria-hidden="true">{{ icon_tiktok }}</span>
      {%- endif -%}
      {%- if section.settings.pinterest_link != blank -%}
        <a class="footer-custom__social" href="{{ section.settings.pinterest_link }}" target="_blank" rel="noopener noreferrer" aria-label="Pinterest">{{ icon_pinterest }}</a>
      {%- else -%}
        <span class="footer-custom__social" aria-hidden="true">{{ icon_pinterest }}</span>
      {%- endif -%}
      {%- if section.settings.email_address != blank -%}
        <a class="footer-custom__social" href="mailto:{{ section.settings.email_address }}" aria-label="Email">{{ icon_email }}</a>
      {%- else -%}
        <span class="footer-custom__social" aria-hidden="true">{{ icon_email }}</span>
      {%- endif -%}
    </div>

    {%- if section.settings.bottom_text != blank -%}
      <div class="footer-custom__inspire">{{ section.settings.bottom_text }}</div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .footer-custom {
    --ft-gutter: clamp(1.25rem, 4vw, 4.5rem);

    position: relative;
    overflow: hidden;
    isolation: isolate;
    background-color: var(--color-background, #f4f1ec);
    color: var(--color-foreground, #1a1a1a);
    padding-block: clamp(2.5rem, 5vw, 4.5rem);
    padding-inline: var(--ft-gutter);
  }

  /* Decorative circular side images — behind content, desktop only */
  .footer-custom__decor {
    display: none;
    position: absolute;
    top: 0;
    z-index: -1;
    width: clamp(220px, 24vw, 360px);
    aspect-ratio: 1;
    border-radius: 50%;
    overflow: hidden;
    pointer-events: none;
  }
  .footer-custom__decor--left { left: 0; transform: translate(-45%, -6%); }
  .footer-custom__decor--right { right: 0; transform: translate(45%, -6%); }
  .footer-custom__decor-image { width: 100%; height: 100%; object-fit: cover; }

  @media screen and (min-width: 990px) {
    .footer-custom__decor { display: block; }
  }

  /* ---------- Top: 3-column split ---------- */
  .footer-custom__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.25rem, 5vw, 3rem);
    align-items: start;
  }

  .footer-custom__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-custom__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    color: inherit;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
  }
  .footer-custom__link svg {
    flex: none;
    opacity: 0.65;
    transition: transform 0.25s ease, opacity 0.25s ease;
  }
  @media (hover: hover) {
    .footer-custom__link:hover { opacity: 0.6; }
    .footer-custom__link:hover svg { transform: translateX(4px); opacity: 1; }
  }

  /* ---------- Center: logo + star + tagline ---------- */
  .footer-custom__center {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }

  .footer-custom__logo-image {
    width: var(--ft-logo-width, 160px);
    height: auto;
    max-width: 100%;
    object-fit: contain;
  }

  .footer-custom__star {
    display: inline-flex;
    width: 1.4rem;
    height: 1.4rem;
    opacity: 0.85;
  }

  .footer-custom__tagline {
    font-size: 0.78rem;
    line-height: 1.7;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.75);
  }
  .footer-custom__tagline > :first-child { margin-block-start: 0; }
  .footer-custom__tagline > :last-child { margin-block-end: 0; }

  /* ---------- Bottom bar ---------- */
  .footer-custom__bottom {
    margin-block-start: clamp(2.5rem, 5vw, 4rem);
    padding-block-start: clamp(1.5rem, 3vw, 2rem);
    border-top: 1px solid rgb(var(--color-foreground-rgb, 26 26 26) / 0.15);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .footer-custom__copyright,
  .footer-custom__inspire {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.65);
  }

  .footer-custom__socials {
    display: flex;
    align-items: center;
    gap: 1.4rem;
  }

  .footer-custom__social {
    display: inline-flex;
    color: inherit;
    transition: opacity 0.2s ease;
  }
  @media (hover: hover) {
    a.footer-custom__social:hover { opacity: 0.55; }
  }

  /* ---------- Desktop ---------- */
  @media screen and (min-width: 990px) {
    .footer-custom__top {
      grid-template-columns: 1fr auto 1fr;
      gap: clamp(2rem, 5vw, 6rem);
      align-items: center;
    }

    .footer-custom__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      text-align: left;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
    }
    .footer-custom__copyright { justify-self: start; }
    .footer-custom__socials { justify-self: center; }
    .footer-custom__inspire { justify-self: end; text-align: right; }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-custom__link svg { transition: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "class": "footer-custom-section",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "Menus"
    },
    {
      "type": "link_list",
      "id": "menu_left",
      "label": "Left menu",
      "default": "footer"
    },
    {
      "type": "link_list",
      "id": "menu_right",
      "label": "Right menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Defaults to your theme logo if left empty."
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 80,
      "max": 300,
      "step": 4,
      "unit": "px",
      "default": 160
    },
    {
      "type": "richtext",
      "id": "tagline",
      "label": "Tagline",
      "default": "<p>Създадени да се движиш.<br>Създадени да постигнеш.</p>"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright",
      "default": "© FORME 2025 | Всички права запазени"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom-right text",
      "default": "Движи се. Вдъхновявай. Бъди ти."
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "instagram_link",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "tiktok_link",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "pinterest_link",
      "label": "Pinterest URL"
    },
    {
      "type": "text",
      "id": "email_address",
      "label": "Email address",
      "info": "Used for the mail icon (opens mailto)."
    },
    {
      "type": "header",
      "content": "Decorative side images (desktop)"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left image"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Right image"
    }
  ]
}
{% endschema %}
