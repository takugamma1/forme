{%- comment -%}
  Custom Value Props (trust badges) — sections/custom-value-props.liquid
  Centred heading over a row of value-prop items. Desktop = 5 across with thin
  vertical separators between them; mobile = 2-column grid with the 5th item
  centred. Each block = an editable SVG icon field + title + description.
  BEM styles + schema below.
{%- endcomment -%}

<section class="value-props color-{{ section.settings.color_scheme }}">
  {%- if section.settings.heading != blank -%}
    <div class="value-props__header">
      <h2 class="value-props__heading">{{ section.settings.heading }}</h2>
      <span class="value-props__rule" aria-hidden="true"></span>
    </div>
  {%- endif -%}

  {%- if section.blocks.size > 0 -%}
    <div class="value-props__row">
      {%- for block in section.blocks -%}
        <div class="value-props__item" {{ block.shopify_attributes }}>
          {%- if block.settings.icon != blank -%}
            <span class="value-props__icon" aria-hidden="true">{{ block.settings.icon }}</span>
          {%- endif -%}
          {%- if block.settings.title != blank -%}
            <h3 class="value-props__title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="value-props__desc">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .value-props {
    --vp-gutter: clamp(1rem, 4vw, 4rem);

    background-color: var(--color-background, #f4f1ec);
    color: var(--color-foreground, #1a1a1a);
    padding-block: clamp(2.5rem, 5vw, 4.5rem);
    padding-inline: var(--vp-gutter);
  }

  /* ---------- Header ---------- */
  .value-props__header {
    text-align: center;
    margin-block-end: clamp(2rem, 4vw, 3.5rem);
  }
  .value-props__heading {
    margin: 0;
    font-weight: 300;
    line-height: 1.2;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-size: clamp(0.95rem, 1.6vw, 1.1rem);
  }
  .value-props__rule {
    display: block;
    width: 2.5rem;
    height: 1px;
    margin: 1.1rem auto 0;
    background-color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.35);
  }

  /* ---------- Row: mobile = 2-col grid (5th centred) ---------- */
  .value-props__row {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1.75rem, 5vw, 2.5rem) 1rem;
  }
  .value-props__item:nth-child(5) {
    grid-column: 1 / -1;
  }

  .value-props__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.75rem;
    padding-inline: clamp(0.5rem, 2vw, 1.5rem);
  }

  .value-props__icon {
    display: inline-flex;
    width: 2.75rem;
    height: 2.75rem;
    color: #a89a88;
  }
  .value-props__icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .value-props__title {
    margin: 0.35rem 0 0;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .value-props__desc {
    margin: 0;
    max-width: 22ch;
    font-size: 0.85rem;
    line-height: 1.6;
    color: rgb(var(--color-foreground-rgb, 26 26 26) / 0.65);
  }

  /* ---------- Desktop: single 5-up row with separators ---------- */
  @media screen and (min-width: 750px) {
    .value-props__row {
      grid-template-columns: repeat(5, 1fr);
      gap: 0;
      align-items: stretch;
    }
    .value-props__item:nth-child(5) {
      grid-column: auto;
    }
    .value-props__item:not(:first-child) {
      border-inline-start: 1px solid rgb(var(--color-foreground-rgb, 26 26 26) / 0.12);
    }
  }
{% endstylesheet %}

{% schema %}
